---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const home = await getEntry('pages', 'home');
const { Content } = await render(home);
---

<BaseLayout title={home.data.title} description={home.data.description}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-50 to-white py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight">
        {home.data.title}
      </h1>
      {home.data.description && (
        <p class="mt-6 text-lg text-gray-600 leading-relaxed max-w-2xl mx-auto">
          {home.data.description}
        </p>
      )}
      <div class="mt-8 flex flex-wrap gap-4 justify-center">
        <a
          href="/events"
          class="px-6 py-3 bg-brand-600 text-white rounded-xl font-medium hover:bg-brand-700 transition-colors shadow-sm"
        >
          Unsere Events
        </a>
        <a
          href="/about"
          class="px-6 py-3 bg-white text-gray-700 rounded-xl font-medium border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-colors"
        >
          Mehr erfahren
        </a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="max-w-3xl mx-auto px-6 py-16">
    <div class="prose prose-gray max-w-none">
      <Content />
    </div>
  </section>

  <!-- Teaser: Nächste Events -->
  <section class="bg-gray-50 py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-gray-900">Bevorstehende Events</h2>
      <p class="mt-3 text-gray-600">Schaut vorbei und seid dabei.</p>
      <a
        href="/events"
        class="mt-6 inline-block px-5 py-2.5 bg-brand-600 text-white rounded-xl text-sm font-medium hover:bg-brand-700 transition-colors"
      >
        Alle Events ansehen →
      </a>
    </div>
  </section>
</BaseLayout>

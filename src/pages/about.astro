---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const about = await getEntry('pages', 'about');
const { Content } = await render(about);
---

<BaseLayout title={about.data.title} description={about.data.description}>
  <!-- Page header -->
  <section class="bg-gradient-to-br from-brand-50 to-white py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900">{about.data.title}</h1>
      {about.data.description && (
        <p class="mt-4 text-lg text-gray-600">{about.data.description}</p>
      )}
    </div>
  </section>

  <!-- Content -->
  <section class="max-w-3xl mx-auto px-6 py-12">
    <div class="prose prose-gray max-w-none prose-headings:font-semibold prose-a:text-brand-600">
      <Content />
    </div>
  </section>
</BaseLayout>

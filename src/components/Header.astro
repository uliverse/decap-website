---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'Über uns' },
  { href: '/events', label: 'Events' },
  { href: '/contact', label: 'Kontakt' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-brand-600 tracking-tight hover:text-brand-700 transition-colors">
      Mein Verein
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
            currentPath === link.href
              ? 'bg-brand-50 text-brand-600'
              : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
      aria-label="Menü öffnen"
    >
      <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <nav class="max-w-5xl mx-auto px-6 py-3 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
            currentPath === link.href
              ? 'bg-brand-50 text-brand-600'
              : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
  });
</script>
